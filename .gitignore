# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/

# Node / frontend build
node_modules/
dist/
build/
.cache/

# Env / secrets — never commit
.env
.env.*
*.key
*.pem

# OS / editor
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/

# Local data / PHI — never commit real patient or trial data
data/local/
*.phi

# Downloaded source ORIGINALS kept local (indexed in sources/MANIFEST.md);
# not committed to keep the repo lean (use Git LFS if sharing binaries later).
sources/**/*.pdf
sources/**/*.doc
sources/**/*.docx
sources/**/*.xls
sources/**/*.xlsx
sources/**/*.ppt
sources/**/*.pptx
sources/**/*.zip
sources/download-log.tsv

# App case store (disk-backed drafts; coded identifiers only, still never committed)
app/data/
