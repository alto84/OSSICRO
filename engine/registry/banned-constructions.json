{
  "_meta": {
    "purpose": "Deterministic register linter registry: LLM mannerisms and AI-slop constructions that must not appear in OSSICRO-generated regulatory documents. Zero-LLM, versioned, false-positive-controlled. A finding is a flag for human review or automated rewrite, never a silent edit.",
    "version": "1.0.0",
    "note": "Patterns are case-insensitive regex fragments matched on word boundaries by register_linter.py. Legitimate regulatory terms (e.g. 'material', 'significant', 'adequate and well-controlled') are deliberately EXCLUDED to control false positives."
  },
  "rules": [
    {"id": "hedge-note", "category": "filler-hedge", "pattern": "it (is|'s) (important|worth|interesting) to note", "severity": "high", "message": "Empty metacommentary hedge.", "suggestion": "State the fact directly."},
    {"id": "should-be-noted", "category": "filler-hedge", "pattern": "it should be noted that", "severity": "high", "message": "Empty hedge.", "suggestion": "Delete; state the point."},
    {"id": "needless-to-say", "category": "filler-hedge", "pattern": "needless to say", "severity": "medium", "message": "Filler.", "suggestion": "Delete."},
    {"id": "not-just-but", "category": "mannerism", "pattern": "not (just|only) [a-z ]{2,40} but (also )?", "severity": "high", "message": "The 'not just X but Y' inflation pattern.", "suggestion": "Make the two claims plainly."},
    {"id": "delve", "category": "mannerism", "pattern": "delve into", "severity": "high", "message": "LLM tell.", "suggestion": "Use 'examine' or 'address'."},
    {"id": "navigate-complexities", "category": "mannerism", "pattern": "navigat(e|ing) the (complex|complexit|landscape|nuance)", "severity": "high", "message": "AI-slop metaphor.", "suggestion": "Name the specific task."},
    {"id": "crucial-role", "category": "mannerism", "pattern": "plays? (a|an) (crucial|vital|pivotal|key|critical|central|important) role", "severity": "medium", "message": "Hollow importance claim.", "suggestion": "State what the thing does."},
    {"id": "testament", "category": "mannerism", "pattern": "(a|is a) testament to", "severity": "high", "message": "Promotional cliche.", "suggestion": "Delete; give the evidence."},
    {"id": "tapestry", "category": "mannerism", "pattern": "(rich )?tapestry", "severity": "high", "message": "AI-slop metaphor.", "suggestion": "Delete."},
    {"id": "ever-evolving", "category": "mannerism", "pattern": "ever[- ]?(evolving|changing)", "severity": "medium", "message": "Filler adjective.", "suggestion": "State the specific change with a date/citation."},
    {"id": "in-todays-world", "category": "mannerism", "pattern": "in today'?s (world|landscape|era|environment)", "severity": "high", "message": "Empty opener.", "suggestion": "Delete."},
    {"id": "realm-of", "category": "mannerism", "pattern": "in the realm of", "severity": "medium", "message": "Filler.", "suggestion": "Use 'in' or delete."},
    {"id": "seamless", "category": "promotional", "pattern": "seamless(ly)?", "severity": "medium", "message": "Marketing adjective.", "suggestion": "Describe the mechanism instead."},
    {"id": "robust-filler", "category": "promotional", "pattern": "robust(ly)?", "severity": "low", "message": "Often filler; keep only if it means statistically robust.", "suggestion": "Use a specific adjective."},
    {"id": "cutting-edge", "category": "promotional", "pattern": "(cutting[- ]edge|state[- ]of[- ]the[- ]art|best[- ]in[- ]class|world[- ]class)", "severity": "high", "message": "Promotional; inappropriate in regulatory prose.", "suggestion": "Delete."},
    {"id": "leverage-verb", "category": "promotional", "pattern": "leverag(e|es|ing) (the |a |an |its )", "severity": "medium", "message": "Business-slop verb.", "suggestion": "Use 'use' or 'apply'."},
    {"id": "empower", "category": "promotional", "pattern": "empower(s|ing|ed)?", "severity": "medium", "message": "Promotional.", "suggestion": "State what the user can do."},
    {"id": "unlock", "category": "promotional", "pattern": "unlock(s|ing)? (the |a |an |new |your )", "severity": "medium", "message": "Marketing verb.", "suggestion": "State the concrete effect."},
    {"id": "game-changer", "category": "promotional", "pattern": "game[- ]?chang(er|ing)", "severity": "high", "message": "Hype.", "suggestion": "Delete."},
    {"id": "revolutionize", "category": "promotional", "pattern": "revolutioniz(e|es|ing|ed)", "severity": "high", "message": "Hype.", "suggestion": "Delete."},
    {"id": "transition-furthermore", "category": "transition-slop", "pattern": "^\\s*(furthermore|moreover|additionally),", "severity": "low", "message": "Overused connective at sentence start.", "suggestion": "Often deletable; join or restructure."},
    {"id": "in-conclusion", "category": "summary-slop", "pattern": "in conclusion,", "severity": "medium", "message": "Hollow summary opener.", "suggestion": "Delete; a regulatory document ends with the requirement, not a wrap-up."},
    {"id": "overall-opener", "category": "summary-slop", "pattern": "^\\s*overall,", "severity": "low", "message": "Summary filler opener.", "suggestion": "Delete or make specific."},
    {"id": "in-summary", "category": "summary-slop", "pattern": "in summary,", "severity": "low", "message": "Often redundant; a Synopsis section is fine, this connective is not.", "suggestion": "Delete."},
    {"id": "ai-self-reference", "category": "mannerism", "pattern": "as an? (ai|language model|assistant)", "severity": "high", "message": "AI self-reference must never appear in a regulatory document.", "suggestion": "Delete entirely."},
    {"id": "i-hope-this", "category": "mannerism", "pattern": "i hope this (helps|is helpful)", "severity": "high", "message": "Chat mannerism.", "suggestion": "Delete."},
    {"id": "certainly-opener", "category": "mannerism", "pattern": "^\\s*(certainly|great question|absolutely)[!,.]", "severity": "high", "message": "Chatbot filler.", "suggestion": "Delete."},
    {"id": "feel-free", "category": "mannerism", "pattern": "feel free to", "severity": "medium", "message": "Chat mannerism.", "suggestion": "State the instruction directly."},
    {"id": "double-hedge", "category": "filler-hedge", "pattern": "(may|might|could) (potentially|possibly|perhaps)", "severity": "medium", "message": "Stacked hedge.", "suggestion": "Use one modal."},
    {"id": "utilize", "category": "wordiness", "pattern": "utiliz(e|es|ing|ation)", "severity": "low", "message": "Prefer 'use'.", "suggestion": "Use 'use'."},
    {"id": "in-order-to", "category": "wordiness", "pattern": "in order to", "severity": "low", "message": "Wordy.", "suggestion": "Use 'to'."},
    {"id": "a-myriad", "category": "mannerism", "pattern": "a myriad of", "severity": "medium", "message": "Cliche.", "suggestion": "Use 'many' or a count."},
    {"id": "plethora", "category": "mannerism", "pattern": "plethora of", "severity": "medium", "message": "Cliche.", "suggestion": "Use 'many' or a count."},
    {"id": "when-it-comes-to", "category": "wordiness", "pattern": "when it comes to", "severity": "low", "message": "Wordy opener.", "suggestion": "Use 'for' or 'regarding'."},
    {"id": "at-the-end-of-the-day", "category": "mannerism", "pattern": "at the end of the day", "severity": "medium", "message": "Cliche.", "suggestion": "Delete."},
    {"id": "paradigm-shift", "category": "promotional", "pattern": "paradigm shift", "severity": "medium", "message": "Hype cliche.", "suggestion": "Describe the specific change."},
    {"id": "holistic", "category": "promotional", "pattern": "holistic(ally)?", "severity": "low", "message": "Often filler.", "suggestion": "Specify the scope."},
    {"id": "synergy", "category": "promotional", "pattern": "synerg(y|ies|istic)", "severity": "low", "message": "Business filler unless pharmacological synergy is meant.", "suggestion": "Keep only for true drug synergy."}
  ]
}
