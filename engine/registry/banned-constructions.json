{
  "_meta": {
    "purpose": "Register-tripwire registry, two tiers. TIER-A (tier='hard-rule') are fact-shaped bright lines that are never legitimate and hard-fail deterministically: chat-transcript residue (a regulatory document must never contain AI self-reference or chatbot openers) and 21 CFR 50.20 exculpatory-consent constructions (a consent document may not contain exculpatory language). TIER-B (tier='example') are dated mannerism/promotional patterns: a NON-BLOCKING smoke signal only, and a set of illustrative, explicitly non-exhaustive EXAMPLES that seed the concept-based voice reviewer's rubric. Voice authority is the concept-based reviewer applying docs/WRITING-PRINCIPLES.md, not this list. See docs/VALIDATION-PHILOSOPHY.md.",
    "version": "2.0.0",
    "note": "Patterns are case-insensitive regex, word-boundary matched by register_linter.py. Tier-B entries are expected to decay as models and writing norms improve; retire them freely — the principles, not the patterns, are the standard. Tier-A entries change only by explicit amendment and carry a citation."
  },
  "rules": [
    {"id": "ai-self-reference", "tier": "hard-rule", "category": "chat-residue", "pattern": "as an? (ai|language model|assistant)", "severity": "high", "message": "AI self-reference must never appear in a regulatory document.", "suggestion": "Delete entirely.", "citation": "Chat-transcript residue; never legitimate in a submission."},
    {"id": "i-hope-this", "tier": "hard-rule", "category": "chat-residue", "pattern": "i hope this (helps|is helpful)", "severity": "high", "message": "Chatbot mannerism.", "suggestion": "Delete.", "citation": "Chat-transcript residue."},
    {"id": "certainly-opener", "tier": "hard-rule", "category": "chat-residue", "pattern": "^\\s*(certainly|great question|absolutely)[!,.]", "severity": "high", "message": "Chatbot filler opener.", "suggestion": "Delete.", "citation": "Chat-transcript residue."},
    {"id": "feel-free", "tier": "hard-rule", "category": "chat-residue", "pattern": "feel free to", "severity": "high", "message": "Chatbot mannerism.", "suggestion": "State the instruction directly.", "citation": "Chat-transcript residue."},

    {"id": "excul-waive", "tier": "hard-rule", "scope": "consent", "category": "exculpatory-50.20", "pattern": "you (hereby )?waive", "severity": "high", "message": "Exculpatory language is prohibited in informed consent.", "suggestion": "Remove; a subject may not be asked to waive or appear to waive any legal right.", "citation": "21 CFR 50.20"},
    {"id": "excul-release", "tier": "hard-rule", "scope": "consent", "category": "exculpatory-50.20", "pattern": "releas(e|es|ing) (the )?(sponsor|investigator|institution|manufacturer)[a-z, ]* from (any |all )?(liability|responsibility|claims?)", "severity": "high", "message": "Exculpatory release language is prohibited in informed consent.", "suggestion": "Remove the release-from-liability construction.", "citation": "21 CFR 50.20"},
    {"id": "excul-not-liable", "tier": "hard-rule", "scope": "consent", "category": "exculpatory-50.20", "pattern": "(shall|will) not be (held )?(liable|responsible) for", "severity": "high", "message": "Waiver-of-liability language is prohibited in informed consent (legitimate in a CTA, not a consent form).", "suggestion": "Remove from the consent document.", "citation": "21 CFR 50.20"},
    {"id": "excul-give-up-rights", "tier": "hard-rule", "scope": "consent", "category": "exculpatory-50.20", "pattern": "give up (any|your|all) (legal )?rights?", "severity": "high", "message": "Consent may not ask a subject to give up any legal right.", "suggestion": "Remove; consent must state the subject waives no legal rights by signing.", "citation": "21 CFR 50.20"},

    {"id": "hedge-note", "tier": "example", "category": "filler-hedge", "pattern": "it (is|'s) (important|worth|interesting) to note", "severity": "high", "message": "Empty metacommentary hedge.", "suggestion": "State the fact directly."},
    {"id": "should-be-noted", "tier": "example", "category": "filler-hedge", "pattern": "it should be noted that", "severity": "high", "message": "Empty hedge.", "suggestion": "Delete; state the point."},
    {"id": "needless-to-say", "tier": "example", "category": "filler-hedge", "pattern": "needless to say", "severity": "medium", "message": "Filler.", "suggestion": "Delete."},
    {"id": "not-just-but", "tier": "example", "category": "mannerism", "pattern": "not (just|only) [a-z ]{2,40} but (also )?", "severity": "high", "message": "The 'not just X but Y' inflation pattern.", "suggestion": "Make the two claims plainly."},
    {"id": "delve", "tier": "example", "category": "mannerism", "pattern": "delve into", "severity": "high", "message": "LLM tell.", "suggestion": "Use 'examine' or 'address'."},
    {"id": "navigate-complexities", "tier": "example", "category": "mannerism", "pattern": "navigat(e|ing) the (complex|complexit|landscape|nuance)", "severity": "high", "message": "AI-slop metaphor.", "suggestion": "Name the specific task."},
    {"id": "crucial-role", "tier": "example", "category": "mannerism", "pattern": "plays? (a|an) (crucial|vital|pivotal|key|critical|central|important) role", "severity": "medium", "message": "Hollow importance claim.", "suggestion": "State what the thing does."},
    {"id": "testament", "tier": "example", "category": "mannerism", "pattern": "(a|is a) testament to", "severity": "high", "message": "Promotional cliche.", "suggestion": "Delete; give the evidence."},
    {"id": "tapestry", "tier": "example", "category": "mannerism", "pattern": "(rich )?tapestry", "severity": "high", "message": "AI-slop metaphor.", "suggestion": "Delete."},
    {"id": "ever-evolving", "tier": "example", "category": "mannerism", "pattern": "ever[- ]?(evolving|changing)", "severity": "medium", "message": "Filler adjective.", "suggestion": "State the specific change with a date/citation."},
    {"id": "in-todays-world", "tier": "example", "category": "mannerism", "pattern": "in today'?s (world|landscape|era|environment)", "severity": "high", "message": "Empty opener.", "suggestion": "Delete."},
    {"id": "realm-of", "tier": "example", "category": "mannerism", "pattern": "in the realm of", "severity": "medium", "message": "Filler.", "suggestion": "Use 'in' or delete."},
    {"id": "seamless", "tier": "example", "category": "promotional", "pattern": "seamless(ly)?", "severity": "medium", "message": "Marketing adjective.", "suggestion": "Describe the mechanism instead."},
    {"id": "robust-filler", "tier": "example", "category": "promotional", "pattern": "robust(ly)?", "severity": "low", "message": "Often filler; keep only if it means statistically robust.", "suggestion": "Use a specific adjective."},
    {"id": "cutting-edge", "tier": "example", "category": "promotional", "pattern": "(cutting[- ]edge|state[- ]of[- ]the[- ]art|best[- ]in[- ]class|world[- ]class)", "severity": "high", "message": "Promotional; inappropriate in regulatory prose.", "suggestion": "Delete."},
    {"id": "leverage-verb", "tier": "example", "category": "promotional", "pattern": "leverag(e|es|ing) (the |a |an |its )", "severity": "medium", "message": "Business-slop verb.", "suggestion": "Use 'use' or 'apply'."},
    {"id": "empower", "tier": "example", "category": "promotional", "pattern": "empower(s|ing|ed)?", "severity": "medium", "message": "Promotional.", "suggestion": "State what the user can do."},
    {"id": "unlock", "tier": "example", "category": "promotional", "pattern": "unlock(s|ing)? (the |a |an |new |your )", "severity": "medium", "message": "Marketing verb.", "suggestion": "State the concrete effect."},
    {"id": "game-changer", "tier": "example", "category": "promotional", "pattern": "game[- ]?chang(er|ing)", "severity": "high", "message": "Hype.", "suggestion": "Delete."},
    {"id": "revolutionize", "tier": "example", "category": "promotional", "pattern": "revolutioniz(e|es|ing|ed)", "severity": "high", "message": "Hype.", "suggestion": "Delete."},
    {"id": "transition-furthermore", "tier": "example", "category": "transition-slop", "pattern": "^\\s*(furthermore|moreover|additionally),", "severity": "low", "message": "Overused connective at sentence start.", "suggestion": "Often deletable; join or restructure."},
    {"id": "in-conclusion", "tier": "example", "category": "summary-slop", "pattern": "in conclusion,", "severity": "medium", "message": "Hollow summary opener.", "suggestion": "Delete; a regulatory document ends with the requirement, not a wrap-up."},
    {"id": "overall-opener", "tier": "example", "category": "summary-slop", "pattern": "^\\s*overall,", "severity": "low", "message": "Summary filler opener.", "suggestion": "Delete or make specific."},
    {"id": "in-summary", "tier": "example", "category": "summary-slop", "pattern": "in summary,", "severity": "low", "message": "Often redundant; a Synopsis section is fine, this connective is not.", "suggestion": "Delete."},
    {"id": "double-hedge", "tier": "example", "category": "filler-hedge", "pattern": "(may|might|could) (potentially|possibly|perhaps)", "severity": "medium", "message": "Stacked hedge.", "suggestion": "Use one modal."},
    {"id": "utilize", "tier": "example", "category": "wordiness", "pattern": "utiliz(e|es|ing|ation)", "severity": "low", "message": "Prefer 'use'.", "suggestion": "Use 'use'."},
    {"id": "in-order-to", "tier": "example", "category": "wordiness", "pattern": "in order to", "severity": "low", "message": "Wordy.", "suggestion": "Use 'to'."},
    {"id": "a-myriad", "tier": "example", "category": "mannerism", "pattern": "a myriad of", "severity": "medium", "message": "Cliche.", "suggestion": "Use 'many' or a count."},
    {"id": "plethora", "tier": "example", "category": "mannerism", "pattern": "plethora of", "severity": "medium", "message": "Cliche.", "suggestion": "Use 'many' or a count."},
    {"id": "when-it-comes-to", "tier": "example", "category": "wordiness", "pattern": "when it comes to", "severity": "low", "message": "Wordy opener.", "suggestion": "Use 'for' or 'regarding'."},
    {"id": "at-the-end-of-the-day", "tier": "example", "category": "mannerism", "pattern": "at the end of the day", "severity": "medium", "message": "Cliche.", "suggestion": "Delete."},
    {"id": "paradigm-shift", "tier": "example", "category": "promotional", "pattern": "paradigm shift", "severity": "medium", "message": "Hype cliche.", "suggestion": "Describe the specific change."},
    {"id": "holistic", "tier": "example", "category": "promotional", "pattern": "holistic(ally)?", "severity": "low", "message": "Often filler.", "suggestion": "Specify the scope."},
    {"id": "synergy", "tier": "example", "category": "promotional", "pattern": "synerg(y|ies|istic)", "severity": "low", "message": "Business filler unless pharmacological synergy is meant.", "suggestion": "Keep only for true drug synergy."}
  ]
}
