  {
    "id": "informed-consent-form-part50-ea",
    "author_party": "physician",
    "title": "Informed Consent Form - Individual-Patient Expanded Access (21 CFR Part 50)",
    "category": "consent",
    "lifecycle_phase": "startup",
    "governing_citations": ["21 CFR 50.25", "21 CFR 50.27", "21 CFR 312.305(c)", "21 CFR 312.60"],
    "owner": "investigator",
    "receiver": "subject",
    "required_fields": ["investigator_name", "site_name", "drug_name", "manufacturer_name", "purpose", "consent_duration", "procedures", "risks", "benefits", "alternatives", "confidentiality_statement", "injury_compensation_statement", "cost_statement", "injury_contact_name", "injury_contact_phone", "research_contact", "irb_name", "irb_phone"],
    "description": "P6 (HITL): the EA-profiled consent draft, framed as TREATMENT USE per FDA's individual-patient expanded-access guidance. Heading-completeness (rule R-ICF-50.25-EA) is NOT adequacy: whether the filled language actually informs THIS patient is the deferred concept rule R-ICF-50.25-ADEQ-EA plus a qualified, IRB-experienced human review — that human review is the release precondition for real-patient use, and the draft carries a PENDING-HUMAN-VERIFICATION banner until it happens. The generic informed-consent-form-part50 remains registered for non-EA routes.",
    "gate": "informed-consent"
  },
